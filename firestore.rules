rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isCR() {
      return isSignedIn() && userDoc().role == 'cr';
    }
    function isCRForBatch(batchId) {
      return isCR() && batchId in userDoc().managedBatches;
    }
    function isCRForIncoming() {
      return isCR() && request.resource.data.batchId in userDoc().managedBatches;
    }
    function isCRForResource() {
      return isCR() && resource.data.batchId in userDoc().managedBatches;
    }

    // ── USERS ──────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      // Owner can update own doc; CR can update enrolledBatches (approve flow)
      allow update: if isOwner(userId) || (isSignedIn() && isCR());
      allow delete: if false;
    }

    // ── BATCHES ────────────────────────────────────────────────
    match /batches/{batchId} {
      allow read: if isSignedIn();
      allow create: if isCR();
      allow update: if isCRForBatch(batchId);
      allow delete: if isCRForBatch(batchId);
    }

    // ── CLASSES ────────────────────────────────────────────────
    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create: if isCRForIncoming();
      allow update: if isCRForIncoming() || isCRForResource();
      allow delete: if isCRForResource();
    }

    // ── TESTS ──────────────────────────────────────────────────
    match /tests/{testId} {
      allow read: if isSignedIn();
      allow create: if isCRForIncoming();
      allow update: if isCRForIncoming() || isCRForResource();
      allow delete: if isCRForResource();
    }

    // ── ASSIGNMENTS ────────────────────────────────────────────
    match /assignments/{assignmentId} {
      allow read: if isSignedIn();
      allow create: if isCRForIncoming();
      allow update: if isCRForIncoming() || isCRForResource();
      allow delete: if isCRForResource();
    }

    // ── ENROLLMENT REQUESTS ────────────────────────────────────
    // KEY FIX: list/query ops can't use resource.data — allow reads
    // for signed-in users and rely on query filters in the app.
    match /enrollmentRequests/{reqId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.uid == request.auth.uid || isCR()
      );
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── NOTIFICATIONS ──────────────────────────────────────────
    // Any signed-in user can create (students → CR, CR → students)
    // Only the recipient reads/updates their own
    match /notifications/{notifId} {
      allow read:   if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ── FCM TOKENS ─────────────────────────────────────────────
    match /fcmTokens/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── COURSES ────────────────────────────────────────────────
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isCR();
    }
  }
}
